PORT=4000

# Required: Neon (or any) Postgres connection string. Progress is stored here.
# Server-side only — do NOT copy this into the frontend.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Optional: enables real AI-generated vocabulary practice passages.
# Without this, the app uses a built-in fallback generator instead (no key needed).
ANTHROPIC_API_KEY=
