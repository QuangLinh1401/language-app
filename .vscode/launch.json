{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Debug (Node)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/server.js",
      "envFile": "${workspaceFolder}/backend/.env",
      "console": "integratedTerminal",
      "restart": true,
      "runtimeExecutable": "node"
    },
    {
      "name": "Frontend: Open in Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src"
    },
    {
      "name": "Frontend: Open in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Frontend (Edge)",
      "configurations": ["Backend: Debug (Node)", "Frontend: Open in Edge"],
      "preLaunchTask": "Frontend: dev",
      "stopAll": true
    }
  ]
}
